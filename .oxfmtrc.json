{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"ignorePatterns": [
		"bun.lock",
		"src/routeTree.gen.ts",
		"worker-configuration.d.ts"
	],
	"useTabs": true,
	"tabWidth": 2,
	"printWidth": 80,
	"sortImports": {
		"newlinesBetween": false
	},
	"sortTailwindcss": {
		"stylesheet": "./src/app.css",
		"functions": ["clsx", "cn", "cva"]
	}
}
